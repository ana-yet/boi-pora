# === Local Development ===
PORT=4000
MONGODB_URI=mongodb://localhost:27017/boi-pora
JWT_SECRET=change-this-to-a-secure-secret-in-production
CORS_ORIGIN=http://localhost:3000
ADMIN_SEED_PASSWORD=change-this-admin-password

# Optional: contact email sent to MyMemory as `de` query param for higher daily character quota (public translate API).
# MYMEMORY_CONTACT_EMAIL=

# === Render Deployment ===
# Set these as Environment Variables in Render Dashboard:
#   MONGODB_URI  → Your MongoDB Atlas connection string (e.g. mongodb+srv://user:pass@cluster.mongodb.net/boi-pora)
#   JWT_SECRET   → Auto-generated if using render.yaml, or set a strong random secret (min 32 chars)
#   CORS_ORIGIN  → Your frontend URL (e.g. https://boi-pora.vercel.app). Comma-separated for multiple origins.
#   PORT         → Render sets this automatically (default 10000)
