# === Local Development ===
PORT=4000
MONGODB_URI=mongodb://localhost:27017/boi-pora
JWT_SECRET=change-this-to-a-secure-secret-in-production
CORS_ORIGIN=http://localhost:3000

# === Vercel Deployment ===
# Set these as Environment Variables in Vercel Dashboard:
#   MONGODB_URI  → Your MongoDB Atlas connection string (e.g. mongodb+srv://user:pass@cluster.mongodb.net/boi-pora)
#   JWT_SECRET   → A strong random secret (min 32 chars). Generate with: openssl rand -hex 32
#   CORS_ORIGIN  → Your frontend URL (e.g. https://boi-pora.vercel.app)
#
# Vercel automatically sets the VERCEL env var — used to tune connection pool size.
